{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "vgblk/video-slider",
  "version": "1.0.0",
  "title": "Video Slider",
  "category": "videoblocks",
  "description": "Video Slider lets you create responsive, customizable video sliders using self-hosted videos, perfect for showcasing your content in a sleek and engaging way.",
  "keywords": [
    "video slider",
    "slider",
    "video",
    "video gallery",
    "video slider gallery"
  ],
  "textdomain": "video-gallery",
  "attributes": {
    "align": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "html": false
  },
  "example": {
    "attributes": {}
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css"
}